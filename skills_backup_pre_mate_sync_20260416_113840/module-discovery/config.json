{
  "name": "module-discovery",
  "stage": "java-discovery",
  "category": "analysis",
  "purpose": "Discover related Java/JSP/JS/config files, URLs, and database touchpoints for a selected module.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "legacySourceRoot"
  ],
  "optionalInputs": [
    "moduleHints.relatedFolders",
    "moduleHints.keywords",
    "moduleHints.knownUrls"
  ],
  "outputFiles": [
    "result.json",
    "discovery-map.json",
    "discovery-evidence.json"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/module-discovery/"
  ],
  "dependencies": [],
  "summaryOutputType": "discovery-summary",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>"
    ]
  }
}
