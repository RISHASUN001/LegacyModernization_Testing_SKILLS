@model FindingsPageDto
@{
    ViewData["Title"] = "Findings";
    var total = Model.Findings.Count;
    var open = Model.Findings.Count(static x => string.Equals(x.Status, "open", StringComparison.OrdinalIgnoreCase));
    var high = Model.Findings.Count(static x => string.Equals(x.Severity, "high", StringComparison.OrdinalIgnoreCase));
}

<h2 class="mb-2">Findings</h2>

<div class="findings-summary-strip mb-3">
    <span class="badge text-bg-light border">total @total</span>
    <span class="badge text-bg-light border">open @open</span>
    <span class="badge text-bg-light border">high @high</span>
    <span class="badge text-bg-light border">recommendations @Model.Recommendations.Count</span>
</div>

<form method="get" class="panel-card p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Module</label>
            <input class="form-control" name="module" value="@Model.ModuleName" />
        </div>
        <div class="col-md-5">
            <label class="form-label">Run ID</label>
            <input class="form-control" name="runId" value="@Model.RunId" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" type="submit">Filter</button>
        </div>
    </div>
</form>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="panel-card p-3 h-100">
            <h3 class="h6">Evidence Matrix</h3>
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Run</th>
                        <th>Stage</th>
                        <th>Issue</th>
                        <th>Cause</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var finding in Model.Findings)
                {
                    <tr>
                        <td><code>@finding.ModuleName/@finding.RunId</code></td>
                        <td>@finding.Stage</td>
                        <td>
                            <div><strong>@finding.FindingType</strong></div>
                            <div class="small text-muted">@finding.Message</div>
                            <details class="findings-details mt-1">
                                <summary class="small">evidence</summary>
                                <div class="small text-muted">@finding.Evidence</div>
                                <div class="small text-muted">@finding.ProvenanceType | conf @finding.Confidence.ToString("0.00")</div>
                            </details>
                        </td>
                        <td>@finding.LikelyCause</td>
                        <td>
                            <span class="status-pill @finding.Status.ToLowerInvariant()">@finding.Status</span>
                            @if (!string.IsNullOrWhiteSpace(finding.ResolvedInRunId))
                            {
                                <div class="small text-muted">Resolved in @finding.ResolvedInRunId</div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card p-3 h-100">
            <h3 class="h6">Recommendations</h3>
            <ul class="mb-0">
                @foreach (var rec in Model.Recommendations)
                {
                    <li class="mb-2">
                        <strong>@rec.Priority</strong> @rec.Message
                        <div class="small text-muted">@rec.Stage / @rec.SkillName / @rec.ProvenanceType</div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
