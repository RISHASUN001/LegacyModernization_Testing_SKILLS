@model RunInputBuilderFormModel
@{
    ViewData["Title"] = "Run Input Builder";
}

<h2 class="mb-1">Run Input Builder</h2>
<p class="text-muted">Generate run-input JSON for the 10-stage modernization pipeline (discovery -> logic -> diagrams -> parity -> test generation -> execution -> findings).</p>

<div class="alert alert-info py-2">
    <strong>Execution model:</strong> this builder creates JSON only. Skill selection is disabled; pipeline skills are resolved by orchestrator stage contracts.
    Copy the JSON and invoke from Copilot/Claude when needed.
</div>

<div class="help-grid mb-3">
    <div class="help-item">
        <div class="summary-label">Required</div>
        <div class="small">moduleName, workflowNames, converted/legacy roots, baseUrl, startUrl, dotnetTestTarget</div>
    </div>
    <div class="help-item">
        <div class="summary-label">Boundary</div>
        <div class="small">module start URL defines route scope for discovery and tests</div>
    </div>
    <div class="help-item">
        <div class="summary-label">Strict Mode</div>
        <div class="small">hints assist naming only; code evidence decides inclusion</div>
    </div>
    <div class="help-item">
        <div class="summary-label">Legacy Mapping</div>
        <div class="small">backend/frontend roots keep Java and JSP mapping bounded</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="post" class="panel-card p-3 mb-3">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Run ID</label>
            <div class="input-group">
                <input class="form-control" name="RunId" id="runIdInput" value="@Model.Page.Draft.RunId" />
                <button class="btn btn-outline-secondary" type="button" id="regenRunIdBtn">Unique</button>
            </div>
            <div class="form-text">Auto-suggests a unique ID by module and timestamp to avoid stale duplicate history rows.</div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Module Name</label>
            <input class="form-control" name="ModuleName" id="moduleNameInput" value="@Model.Page.Draft.ModuleName" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Base URL</label>
            <input class="form-control" name="BaseUrl" id="baseUrlInput" value="@Model.Page.Draft.BaseUrl" placeholder="http://localhost:5001" />
            <div class="form-text">Used for E2E, Playwright, and DevTools route probing against the live local app.</div>
        </div>
        <div class="col-md-12">
            <label class="form-label">workflowNames[] (comma/newline separated)</label>
            <textarea class="form-control" rows="2" name="WorkflowNamesText" placeholder="Login&#10;ForgotPassword">@Model.Page.Draft.WorkflowNamesText</textarea>
        </div>
        <div class="col-md-6">
            <label class="form-label">convertedRoots[] (comma/newline separated)</label>
            <textarea class="form-control" rows="2" name="ConvertedRootsText" placeholder="/Users/risha/Documents/Buildathon/src">@Model.Page.Draft.ConvertedRootsText</textarea>
        </div>
        <div class="col-md-6">
            <label class="form-label">dotnetTestTarget</label>
            <input class="form-control" name="DotnetTestTarget" value="@Model.Page.Draft.DotnetTestTarget" placeholder="/Users/risha/Documents/Buildathon/LegacyModernization.slnx" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Legacy Source Root</label>
            <input class="form-control" name="LegacySourceRoot" value="@Model.Page.Draft.LegacySourceRoot" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Converted Source Root</label>
            <input class="form-control" name="ConvertedSourceRoot" value="@Model.Page.Draft.ConvertedSourceRoot" />
        </div>

        <div class="col-md-6">
            <label class="form-label">legacyBackendRoots[] (comma/newline separated)</label>
            <textarea class="form-control" rows="2" name="LegacyBackendRootsText" placeholder="/Users/risha/Documents/Buildathon/samples/legacy-java-app/src">@Model.Page.Draft.LegacyBackendRootsText</textarea>
            <div class="form-text">Legacy Backend Root fallback still supported below.</div>
        </div>
        <div class="col-md-6">
            <label class="form-label">legacyFrontendRoots[] (comma/newline separated)</label>
            <textarea class="form-control" rows="2" name="LegacyFrontendRootsText" placeholder="/Users/risha/Documents/Buildathon/samples/legacy-java-app/web">@Model.Page.Draft.LegacyFrontendRootsText</textarea>
            <div class="form-text">Legacy Frontend Root fallback still supported below.</div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Legacy Backend Root fallback (optional)</label>
            <input class="form-control" name="LegacyBackendRoot" value="@Model.Page.Draft.LegacyBackendRoot" placeholder="/src/edcs" />
            <div class="form-text">If empty, Legacy Source Root is used.</div>
        </div>
        <div class="col-md-6">
            <label class="form-label">Legacy Frontend Root fallback (optional)</label>
            <input class="form-control" name="LegacyFrontendRoot" value="@Model.Page.Draft.LegacyFrontendRoot" placeholder="/src/jsp" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Converted Module Root (optional)</label>
            <input class="form-control" name="ConvertedModuleRoot" value="@Model.Page.Draft.ConvertedModuleRoot" placeholder="Path to module folder/project" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Entry Controller Name (optional)</label>
            <input class="form-control" name="EntryControllerName" value="@Model.Page.Draft.EntryControllerName" placeholder="HomeController" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Home/Index URL (optional)</label>
            <input class="form-control" name="HomeUrl" value="@Model.Page.Draft.HomeUrl" placeholder="/home/index" />
        </div>
        <div class="col-md-6">
            <label class="form-label">startUrl (required boundary)</label>
            <input class="form-control" name="ModuleStartUrl" value="@Model.Page.Draft.ModuleStartUrl" placeholder="/checklist or http://localhost:5001/checklist" required />
            <div class="form-text">This is the primary route boundary for module workflow discovery and test generation.</div>
        </div>

        <div class="col-md-12">
            <label class="form-label">BRS Path (optional)</label>
            <input class="form-control" name="BrsPath" value="@Model.Page.Draft.BrsPath" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Related Folders</label>
            <textarea class="form-control" rows="5" name="RelatedFoldersText">@Model.Page.Draft.RelatedFoldersText</textarea>
        </div>
        <div class="col-md-4">
            <label class="form-label">Known URLs</label>
            <textarea class="form-control" rows="5" name="KnownUrlsText">@Model.Page.Draft.KnownUrlsText</textarea>
        </div>
        <div class="col-md-4">
            <label class="form-label">Keywords</label>
            <textarea class="form-control" rows="5" name="KeywordsText">@Model.Page.Draft.KeywordsText</textarea>
        </div>

        <div class="col-md-4">
            <label class="form-label">Menu Path Hints (optional)</label>
            <textarea class="form-control" rows="4" name="MenuPathHintsText" placeholder="Home > Menu > Checklist">@Model.Page.Draft.MenuPathHintsText</textarea>
        </div>
        <div class="col-md-4">
            <label class="form-label">Expected Workflow Names (optional)</label>
            <textarea class="form-control" rows="4" name="ExpectedWorkflowNamesText" placeholder="Perform Checklist\nChecklist History Report">@Model.Page.Draft.ExpectedWorkflowNamesText</textarea>
            <div class="form-text">If unknown, leave empty. Workflows are inferred automatically.</div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Controller/Action Hints (optional)</label>
            <textarea class="form-control" rows="4" name="ControllerActionHintsText" placeholder="Home/Index\nChecklist/Perform">@Model.Page.Draft.ControllerActionHintsText</textarea>
        </div>

        <div class="col-md-6">
            <label class="form-label">Java Package Hints (optional)</label>
            <textarea class="form-control" rows="3" name="JavaPackageHintsText" placeholder="com.company.checklist">@Model.Page.Draft.JavaPackageHintsText</textarea>
        </div>
        <div class="col-md-6">
            <label class="form-label">JSP Folder Hints (optional)</label>
            <textarea class="form-control" rows="3" name="JspFolderHintsText" placeholder="/checklist\n/reports/checklist">@Model.Page.Draft.JspFolderHintsText</textarea>
        </div>

        <div class="col-md-12">
            <label class="form-label">Expected Terminal URLs (optional)</label>
            <textarea class="form-control" rows="2" name="ExpectedTerminalUrlsText" placeholder="/dashboard\n/checklist/history">@Model.Page.Draft.ExpectedTerminalUrlsText</textarea>
        </div>

        <div class="col-md-6">
            <label class="form-label">Target URL (optional)</label>
            <input class="form-control" name="TargetUrl" value="@Model.Page.Draft.TargetUrl" placeholder="/checklist/perform or http://localhost:5276/checklist/perform" />
            <div class="form-text">Optional override. If Module Start URL is set, it is used as target boundary.</div>
        </div>
        <div class="col-md-6">
            <label class="form-label">Module Scope Hint (optional, up to 20 words)</label>
            <textarea class="form-control" rows="2" name="ModuleScopeHint" placeholder="testing one menu item only, checklist perform flow">@Model.Page.Draft.ModuleScopeHint</textarea>
            <div class="form-text">Short natural-language hint to narrow discovery/test generation scope.</div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Architecture Policy</label>
            @{ var architecturePolicy = (Model.Page.Draft.ArchitecturePolicy ?? "module-first").Trim().ToLowerInvariant(); }
            <select class="form-select" name="ArchitecturePolicy">
                @if (architecturePolicy == "module-first")
                {
                    <option value="module-first" selected>module-first</option>
                }
                else
                {
                    <option value="module-first">module-first</option>
                }
                @if (architecturePolicy == "balanced")
                {
                    <option value="balanced" selected>balanced</option>
                }
                else
                {
                    <option value="balanced">balanced</option>
                }
                @if (architecturePolicy == "clean-architecture")
                {
                    <option value="clean-architecture" selected>clean-architecture</option>
                }
                else
                {
                    <option value="clean-architecture">clean-architecture</option>
                }
            </select>
        </div>
        <div class="col-md-8">
            <label class="form-label">Allowed Cross-Modules (one per line)</label>
            <textarea class="form-control" rows="2" name="AllowedCrossModulesText" placeholder="Shared">@Model.Page.Draft.AllowedCrossModulesText</textarea>
        </div>
        <div class="col-md-6">
            <input type="hidden" name="StrictModuleOnly" value="false" />
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="StrictModuleOnly" value="true" @(Model.Page.Draft.StrictModuleOnly ? "checked" : string.Empty) />
                <label class="form-check-label">Strict module-only scan</label>
            </div>
            <div class="form-text">When enabled, discovery excludes unrelated module files unless explicitly allow-listed.</div>
        </div>
        <div class="col-md-6">
            <input type="hidden" name="GenerateModuleClaudeMd" value="false" />
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="GenerateModuleClaudeMd" value="true" @(Model.Page.Draft.GenerateModuleClaudeMd ? "checked" : string.Empty) />
                <label class="form-check-label">Generate module Claude guidance artifact</label>
            </div>
            <div class="form-text">Writes module-only CLAUDE guidance under artifacts for this run.</div>
        </div>

        <div class="col-md-6">
            <input type="hidden" name="StrictAIGeneration" value="false" />
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" name="StrictAIGeneration" value="true" @(Model.Page.Draft.StrictAIGeneration ? "checked" : string.Empty) />
                <label class="form-check-label">Strict AI-first generation</label>
            </div>
            <div class="form-text">Disables fallback test/scenario generation; pipeline fails when evidence is insufficient.</div>
        </div>

        <div class="col-md-6">
            <input type="hidden" name="EnableUserInputPrompting" value="false" />
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" name="EnableUserInputPrompting" value="true" @(Model.Page.Draft.EnableUserInputPrompting ? "checked" : string.Empty) />
                <label class="form-check-label">Enable user input prompting</label>
            </div>
            <div class="form-text">When enabled, browser/test stages can request missing form input data before execution.</div>
        </div>

        <div class="col-md-12">
            <h3 class="h6 mt-2">Optional Category Commands (for strict preflight command resolution)</h3>
            <div class="alert alert-info py-2 mt-2 mb-0 small">
                <div><strong>What this is for:</strong> each execution category can run a real command. If blank, skills try auto-detection; if set, preflight is more reliable.</div>
                <div class="mt-1">These defaults are starter values; change them to match your repo paths and tooling.</div>
            </div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Unit Command</label>
            <input class="form-control" name="UnitCommand" value="@Model.Page.Draft.UnitCommand" placeholder="dotnet test ./tests/UnitTests.csproj" />
            <div class="form-text">Runs unit-level logic/validator tests.</div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Integration Command</label>
            <input class="form-control" name="IntegrationCommand" value="@Model.Page.Draft.IntegrationCommand" />
            <div class="form-text">Runs service + database/infrastructure integration tests.</div>
        </div>
        <input type="hidden" name="ApiCommand" value="@Model.Page.Draft.ApiCommand" />
        <div class="col-md-4">
            <label class="form-label">E2E Command</label>
            <input class="form-control" name="E2eCommand" value="@Model.Page.Draft.E2eCommand" placeholder="python3 -m pytest -m e2e" />
            <div class="form-text">Runs full user journey tests end-to-end.</div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Edge Case Command</label>
            <input class="form-control" name="EdgeCaseCommand" value="@Model.Page.Draft.EdgeCaseCommand" />
            <div class="form-text">Runs boundary/failure/retry regression test suite.</div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Playwright Command</label>
            <input class="form-control" name="PlaywrightCommand" value="@Model.Page.Draft.PlaywrightCommand" placeholder="python3 -m pytest -m playwright" />
            <div class="form-text">Runs browser automation suite used for UI evidence capture.</div>
        </div>

    </div>

    <div class="mt-3 d-flex flex-wrap gap-2">
        <button class="btn btn-primary" type="submit" name="submitAction" value="preview">Refresh Preview</button>
        <button class="btn btn-outline-secondary" type="button" id="copyJsonBtn">Copy JSON</button>
        <button class="btn btn-outline-secondary" type="button" id="downloadJsonBtn">Export JSON</button>
    </div>
</form>

<div class="panel-card p-3">
    <h3 class="h6">Generated JSON</h3>
    <pre class="json-preview" id="jsonPreview">@Model.Page.GeneratedJson</pre>
</div>

@section Scripts {
<script>
(() => {
    const preview = document.getElementById('jsonPreview');
    const copy = document.getElementById('copyJsonBtn');
    const download = document.getElementById('downloadJsonBtn');
    const runIdInput = document.getElementById('runIdInput');
    const moduleNameInput = document.getElementById('moduleNameInput');
    const regenRunIdBtn = document.getElementById('regenRunIdBtn');

    const toSafeSlug = (value) => (value || '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '') || 'module';

    const makeUniqueRunId = () => {
        const moduleSlug = toSafeSlug(moduleNameInput?.value);
        const now = new Date();
        const y = now.getFullYear();
        const m = String(now.getMonth() + 1).padStart(2, '0');
        const d = String(now.getDate()).padStart(2, '0');
        const hh = String(now.getHours()).padStart(2, '0');
        const mm = String(now.getMinutes()).padStart(2, '0');
        const ss = String(now.getSeconds()).padStart(2, '0');
        return `${moduleSlug}-test-${y}${m}${d}-${hh}${mm}${ss}`;
    };

    const ensureRunId = (force = false) => {
        if (!runIdInput) {
            return;
        }
        const current = (runIdInput.value || '').trim();
        if (!force && current && !/^run-001$/i.test(current)) {
            return;
        }
        runIdInput.value = makeUniqueRunId();
    };

    regenRunIdBtn?.addEventListener('click', () => ensureRunId(true));
    moduleNameInput?.addEventListener('change', () => ensureRunId(true));
    ensureRunId();

    copy?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(preview.textContent || '');
        copy.textContent = 'Copied';
        setTimeout(() => copy.textContent = 'Copy JSON', 1000);
    });

    download?.addEventListener('click', () => {
        const blob = new Blob([preview.textContent || ''], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'module-run-input.json';
        link.click();
        URL.revokeObjectURL(url);
    });
})();
</script>
}
