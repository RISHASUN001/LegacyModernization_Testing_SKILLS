@model ModuleRunsPageDto
@{
    ViewData["Title"] = "Module Runs";
}

<h2 class="mb-2">Module Runs</h2>
<p class="text-muted">Open any run to inspect the complete 7-stage pipeline.</p>

<form method="get" class="panel-card p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-9">
            <label class="form-label">Module Filter</label>
            <input class="form-control" name="module" value="@Model.ModuleFilter" placeholder="Checklist" />
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100" type="submit">Apply</button>
        </div>
    </div>
</form>

<div class="panel-card p-3">
    <table class="table table-striped align-middle mb-0">
        <thead>
            <tr>
                <th>Module</th>
                <th>Run ID</th>
                <th>Status</th>
                <th>Started</th>
                <th>Summary</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var run in Model.Runs)
        {
            <tr>
                <td>@run.ModuleName</td>
                <td><code>@run.RunId</code></td>
                <td><span class="status-pill @run.Status.ToLowerInvariant()">@run.Status</span></td>
                <td>@run.StartedAt</td>
                <td>@run.Summary</td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Pipeline" asp-route-moduleName="@run.ModuleName" asp-route-runId="@run.RunId">Open Pipeline</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
