@model RunPipelinePageDto
@{
    ViewData["Title"] = "7-Stage Pipeline";
    var logicFlowNodes = (Model.LogicUnderstanding.FlowDetails.Any()
            ? Model.LogicUnderstanding.FlowDetails.Select(static x => x.Value)
            : Model.LogicUnderstanding.ImportantFlows)
        .Where(static x => !string.IsNullOrWhiteSpace(x))
        .Take(6)
        .ToList();
    var totalFindings = Model.Findings.Findings.Count;
    var openFindings = Model.Findings.Findings.Count(static x => string.Equals(x.Status, "open", StringComparison.OrdinalIgnoreCase));
    var executionFailures = Model.Execution.TestCategories.Sum(static x => x.Failed);
    var executionTotal = Model.Execution.TestCategories.Sum(static x => x.TotalCount);
    var runWarnings = Model.Execution.TestCategories.Sum(static x => x.Warnings);
    var missingTestApi = !string.Equals(Model.Execution.Playwright.TestApiStatus, "present", StringComparison.OrdinalIgnoreCase);
    var fallbackTestApiEndpoint = $"{Context.Request.Scheme}://{Context.Request.Host}/api/test";
    var screenshotArtifacts = Model.Execution.Playwright.Screenshots
        .Where(static x => !string.IsNullOrWhiteSpace(x))
        .Take(8)
        .ToList();
    var dependencyViolations = Model.Parity.DependencyParity.Violations.Count;
    var dependencyCount = Model.Parity.DependencyParity.Dependencies.Count;
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
    <div>
        <h2 class="mb-1">@Model.ModuleName / @Model.RunId</h2>
        <div class="text-muted">@Model.StartedAt → @Model.EndedAt</div>
        <div class="small mt-1">@Model.Summary</div>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="status-pill @Model.Status.ToLowerInvariant()">@Model.Status</span>
        <a class="btn btn-outline-primary btn-sm" asp-action="IterationComparison" asp-route-moduleName="@Model.ModuleName">All Iterations</a>
    </div>
</div>

<div class="panel-card p-3 mb-4">
    <div class="pipeline-summary-grid mb-3">
        <div class="pipeline-summary-card">
            <div class="summary-label">Execution Coverage</div>
            <div class="summary-value">@executionTotal scenarios</div>
            <div class="small text-muted">failed @executionFailures, warnings @runWarnings</div>
        </div>
        <div class="pipeline-summary-card">
            <div class="summary-label">Findings</div>
            <div class="summary-value">@totalFindings total</div>
            <div class="small text-muted">open @openFindings</div>
        </div>
        <div class="pipeline-summary-card">
            <div class="summary-label">Parity Score</div>
            <div class="summary-value">@Model.Parity.ParityScore%</div>
            <div class="small text-muted">@Model.Parity.PassedChecks/@Model.Parity.TotalChecks checks passed</div>
        </div>
        <div class="pipeline-summary-card">
            <div class="summary-label">Data Confidence</div>
            <div class="summary-value">@Model.LogicUnderstanding.Confidence.ToString("0.00")</div>
            <div class="small text-muted">logic understanding source confidence</div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        @foreach (var stage in Model.StageStatuses)
        {
            <a class="btn btn-sm btn-outline-secondary" href="#stage-@stage.StageId">
                @stage.StageTitle
                <span class="ms-1 status-pill @stage.Status.ToLowerInvariant()">@stage.Status</span>
            </a>
        }
        <a class="btn btn-sm btn-outline-secondary" href="#stage-parity">Parity Analysis</a>
    </div>
</div>

<section class="panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">Guided View</h3>
        <span class="stage-pill">purpose / scope / policy / dependencies</span>
    </div>

    <ul class="nav nav-pills pipeline-tabs mb-3" id="pipelineSubTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="overview-tab" data-bs-toggle="pill" data-bs-target="#overview-pane" type="button" role="tab" aria-controls="overview-pane" aria-selected="true">Overview</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="scope-tab" data-bs-toggle="pill" data-bs-target="#scope-pane" type="button" role="tab" aria-controls="scope-pane" aria-selected="false">Scope and Policy</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="architecture-tab" data-bs-toggle="pill" data-bs-target="#architecture-pane" type="button" role="tab" aria-controls="architecture-pane" aria-selected="false">Architecture</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="dependency-tab" data-bs-toggle="pill" data-bs-target="#dependency-pane" type="button" role="tab" aria-controls="dependency-pane" aria-selected="false">Parity Dependencies</button>
        </li>
    </ul>

    <div class="tab-content pipeline-tab-content">
        <div class="tab-pane fade show active" id="overview-pane" role="tabpanel" aria-labelledby="overview-tab" tabindex="0">
            <p class="mb-2">This run validates modernization fidelity for <strong>@Model.ModuleName</strong> by combining scoped discovery, architecture conformance, and execution evidence.</p>
            <div class="pipeline-summary-grid">
                <div class="pipeline-summary-card">
                    <div class="summary-label">Module Purpose</div>
                    <div class="small">@Model.LogicUnderstanding.ModulePurpose</div>
                </div>
                <div class="pipeline-summary-card">
                    <div class="summary-label">Scope Focus</div>
                    <div class="small">@(string.IsNullOrWhiteSpace(Model.Discovery.ScopeContext.ScopeHint) ? "No explicit scope hint" : Model.Discovery.ScopeContext.ScopeHint)</div>
                </div>
                <div class="pipeline-summary-card">
                    <div class="summary-label">Architecture Policy</div>
                    <div class="small">@Model.ArchitectureReview.ArchitecturePolicy</div>
                </div>
                <div class="pipeline-summary-card">
                    <div class="summary-label">Dependency Violations</div>
                    <div class="small">@dependencyViolations of @dependencyCount dependencies</div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="scope-pane" role="tabpanel" aria-labelledby="scope-tab" tabindex="0">
            <div class="row g-3">
                <div class="col-lg-4">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Discovery Scope</div>
                        <div class="small">strictModuleOnly: <strong>@Model.Discovery.ScopeContext.StrictModuleOnly</strong></div>
                        <div class="small">targetUrlPath: <code>@Model.Discovery.ScopeContext.TargetUrlPath</code></div>
                        <div class="small">scopeHint: @Model.Discovery.ScopeContext.ScopeHint</div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Logic Scope Applied</div>
                        <div class="small">targetUrl: <code>@Model.LogicUnderstanding.ScopeApplied.TargetUrl</code></div>
                        <div class="small">scopeHint: @Model.LogicUnderstanding.ScopeApplied.ScopeHint</div>
                        <div class="small">scopeTerms: @string.Join(", ", Model.LogicUnderstanding.ScopeApplied.ScopeTerms)</div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Test Plan Scope Applied</div>
                        <div class="small">targetUrl: <code>@Model.TestPlan.ScopeApplied.TargetUrl</code></div>
                        <div class="small">scopeHint: @Model.TestPlan.ScopeApplied.ScopeHint</div>
                        <div class="small">scopeTerms: @string.Join(", ", Model.TestPlan.ScopeApplied.ScopeTerms)</div>
                    </div>
                </div>
            </div>
            <div class="small text-muted mt-2">Purpose: keep generated logic and test scenarios aligned with the intended module boundary.</div>
        </div>

        <div class="tab-pane fade" id="architecture-pane" role="tabpanel" aria-labelledby="architecture-tab" tabindex="0">
            <div class="row g-3">
                <div class="col-lg-6">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Architecture Policy</div>
                        <div class="summary-value">@Model.ArchitectureReview.ArchitecturePolicy</div>
                        <div class="small text-muted">Confidence: @Model.ArchitectureReview.Confidence.ToString("0.00")</div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Why It Matters</div>
                        <div class="small">Policy-driven checks ensure modernization does not silently introduce unsafe layering or accidental coupling.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="dependency-pane" role="tabpanel" aria-labelledby="dependency-tab" tabindex="0">
            <div class="row g-3">
                <div class="col-lg-4">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Allowed Cross Modules</div>
                        <ul class="mb-0">
                            @foreach (var allowed in Model.Parity.DependencyParity.AllowedCrossModules)
                            {
                                <li>@allowed</li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Detected Dependencies</div>
                        <ul class="mb-0">
                            @if (Model.Parity.DependencyParity.Dependencies.Any())
                            {
                                @foreach (var dep in Model.Parity.DependencyParity.Dependencies)
                                {
                                    <li>@dep</li>
                                }
                            }
                            else
                            {
                                <li class="text-muted">No dependencies detected.</li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="pipeline-summary-card h-100">
                        <div class="summary-label">Violations</div>
                        <ul class="mb-0">
                            @if (Model.Parity.DependencyParity.Violations.Any())
                            {
                                @foreach (var violation in Model.Parity.DependencyParity.Violations)
                                {
                                    <li class="text-danger">@violation</li>
                                }
                            }
                            else
                            {
                                <li class="text-success">No cross-module dependency violations.</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
            <div class="small text-muted mt-2">Purpose: enforce module boundaries while permitting explicit shared dependencies.</div>
        </div>
    </div>
</section>

<section id="stage-discovery" class="stage-section panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">1. Discovery</h3>
        <span class="stage-pill">related Java/JSP/JS/config/URL/DB touchpoints</span>
    </div>
    <div class="row g-3">
        <div class="col-lg-4">
            <h4 class="h6">Java Files</h4>
            <ul>@foreach (var x in Model.Discovery.JavaFiles) { <li><code>@x</code></li> }</ul>
        </div>
        <div class="col-lg-4">
            <h4 class="h6">JSP Files</h4>
            <ul>@foreach (var x in Model.Discovery.JspFiles) { <li><code>@x</code></li> }</ul>
        </div>
        <div class="col-lg-4">
            <h4 class="h6">JS Files</h4>
            <ul>@foreach (var x in Model.Discovery.JsFiles) { <li><code>@x</code></li> }</ul>
        </div>
        <div class="col-lg-4">
            <h4 class="h6">Config Files</h4>
            <ul>@foreach (var x in Model.Discovery.ConfigFiles) { <li><code>@x</code></li> }</ul>
        </div>
        <div class="col-lg-4">
            <h4 class="h6">URLs</h4>
            <ul>
                @if (Model.Discovery.UrlDetails.Any())
                {
                    @foreach (var x in Model.Discovery.UrlDetails)
                    {
                        <li>
                            <code>@x.Value</code>
                            <span class="badge text-bg-light ms-1">@x.ProvenanceType</span>
                            <span class="small text-muted ms-1">conf: @x.Confidence.ToString("0.00")</span>
                        </li>
                    }
                }
                else
                {
                    @foreach (var x in Model.Discovery.Urls) { <li><code>@x</code></li> }
                }
            </ul>
        </div>
        <div class="col-lg-4">
            <h4 class="h6">DB Touchpoints</h4>
            <ul>
                @if (Model.Discovery.DbTouchpointDetails.Any())
                {
                    @foreach (var x in Model.Discovery.DbTouchpointDetails)
                    {
                        <li>
                            @x.Value
                            <span class="badge text-bg-light ms-1">@x.ProvenanceType</span>
                            <span class="small text-muted ms-1">conf: @x.Confidence.ToString("0.00")</span>
                        </li>
                    }
                }
                else
                {
                    @foreach (var x in Model.Discovery.DbTouchpoints) { <li>@x</li> }
                }
            </ul>
        </div>
        <div class="col-lg-12">
            <h4 class="h6">Entrypoint Hints</h4>
            <ul>
                @foreach (var hint in Model.Discovery.EntrypointHints)
                {
                    <li>
                        <code>@hint.Value</code>
                        <span class="badge text-bg-light ms-1">@hint.ProvenanceType</span>
                        <span class="small text-muted ms-1">conf: @hint.Confidence.ToString("0.00")</span>
                    </li>
                }
            </ul>
            <div class="small text-muted">Discovery confidence: @Model.Discovery.Confidence.ToString("0.00")</div>
        </div>
    </div>
    <div class="small text-muted mt-2">Source: <code>@Model.Discovery.SourceArtifactPath</code></div>
    @if (Model.Discovery.ScopeContext.ScopeTokens.Any())
    {
        <div class="small text-muted mt-1">Scope tokens: @string.Join(", ", Model.Discovery.ScopeContext.ScopeTokens)</div>
    }
</section>

<section id="stage-logic-understanding" class="stage-section panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">2. Logic Understanding</h3>
        <span class="stage-pill">purpose / flows / rules / preserve list</span>
    </div>
    <p><strong>Module Purpose:</strong> @Model.LogicUnderstanding.ModulePurpose</p>
    @if (logicFlowNodes.Any())
    {
        <h4 class="h6">Logic Flow Diagram</h4>
        <div class="logic-diagram" role="img" aria-label="Module logic flow represented with arrow links">
            @for (var i = 0; i < logicFlowNodes.Count; i++)
            {
                <span class="logic-node">@logicFlowNodes[i]</span>
                @if (i < logicFlowNodes.Count - 1)
                {
                    <span class="logic-arrow">→</span>
                }
            }
        </div>
        <div class="small text-muted mb-2">Use this as the high-level behavior map for scenario tests and parity checks.</div>
    }
    <div class="row g-3">
        <div class="col-lg-6">
            <h4 class="h6">Important Flows</h4>
            <ul>
                @if (Model.LogicUnderstanding.FlowDetails.Any())
                {
                    @foreach (var x in Model.LogicUnderstanding.FlowDetails)
                    {
                        <li>@x.Value <span class="badge text-bg-light ms-1">@x.ProvenanceType</span> <span class="small text-muted">conf: @x.Confidence.ToString("0.00")</span></li>
                    }
                }
                else
                {
                    @foreach (var x in Model.LogicUnderstanding.ImportantFlows) { <li>@x</li> }
                }
            </ul>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">Rules</h4>
            <ul>
                @if (Model.LogicUnderstanding.RuleDetails.Any())
                {
                    @foreach (var x in Model.LogicUnderstanding.RuleDetails)
                    {
                        <li>@x.Value <span class="badge text-bg-light ms-1">@x.ProvenanceType</span> <span class="small text-muted">conf: @x.Confidence.ToString("0.00")</span></li>
                    }
                }
                else
                {
                    @foreach (var x in Model.LogicUnderstanding.Rules) { <li>@x</li> }
                }
            </ul>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">Dependencies</h4>
            <ul>@foreach (var x in Model.LogicUnderstanding.Dependencies) { <li>@x</li> }</ul>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">Must Preserve</h4>
            <ul>@foreach (var x in Model.LogicUnderstanding.MustPreserve) { <li>@x</li> }</ul>
        </div>
    </div>
    <div class="small text-muted mt-2">Logic confidence: @Model.LogicUnderstanding.Confidence.ToString("0.00")</div>
    @if (Model.LogicUnderstanding.ScopeApplied.ScopeTerms.Any())
    {
        <div class="small text-muted mt-1">Scope applied: @string.Join(", ", Model.LogicUnderstanding.ScopeApplied.ScopeTerms)</div>
    }
    @if (Model.LogicUnderstanding.Unknowns.Any())
    {
        <div class="mt-2">
            <h4 class="h6">Unknowns</h4>
            <ul>@foreach (var x in Model.LogicUnderstanding.Unknowns) { <li>@x</li> }</ul>
        </div>
    }
</section>

<section id="stage-parity" class="stage-section panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">Parity Analysis</h3>
        <span class="stage-pill">legacy Java vs converted C# functional closeness</span>
    </div>

    <div class="row g-3 mb-2">
        <div class="col-md-3"><div class="border rounded p-2"><small class="text-muted">Parity Score</small><div class="fw-semibold">@Model.Parity.ParityScore%</div></div></div>
        <div class="col-md-3"><div class="border rounded p-2"><small class="text-muted">Total Checks</small><div class="fw-semibold">@Model.Parity.TotalChecks</div></div></div>
        <div class="col-md-3"><div class="border rounded p-2"><small class="text-muted">Passed Checks</small><div class="fw-semibold text-success">@Model.Parity.PassedChecks</div></div></div>
        <div class="col-md-3"><div class="border rounded p-2"><small class="text-muted">Failed Checks</small><div class="fw-semibold text-danger">@Model.Parity.FailedChecks</div></div></div>
    </div>

    <div class="small text-muted mb-2">Confidence: @Model.Parity.Confidence.ToString("0.00")</div>

    <div class="row g-3 mb-3">
        <div class="col-lg-4">
            <h4 class="h6">Allowed Cross Modules</h4>
            <ul>
                @foreach (var allowed in Model.Parity.DependencyParity.AllowedCrossModules)
                {
                    <li>@allowed</li>
                }
            </ul>
        </div>
        <div class="col-lg-4">
            <h4 class="h6">Dependencies</h4>
            <ul>
                @if (Model.Parity.DependencyParity.Dependencies.Any())
                {
                    @foreach (var dep in Model.Parity.DependencyParity.Dependencies)
                    {
                        <li>@dep</li>
                    }
                }
                else
                {
                    <li class="text-muted">No dependency evidence captured.</li>
                }
            </ul>
        </div>
        <div class="col-lg-4">
            <h4 class="h6">Dependency Violations</h4>
            <ul>
                @if (Model.Parity.DependencyParity.Violations.Any())
                {
                    @foreach (var violation in Model.Parity.DependencyParity.Violations)
                    {
                        <li class="text-danger">@violation</li>
                    }
                }
                else
                {
                    <li class="text-success">No dependency policy violations.</li>
                }
            </ul>
        </div>
    </div>

    <div class="table-responsive mb-2">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Parity Check</th>
                    <th>Status</th>
                    <th>Evidence</th>
                    <th>Confidence</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var check in Model.Parity.Checks)
            {
                <tr>
                    <td>@check.Name</td>
                    <td><span class="status-pill @check.Status.ToLowerInvariant()">@check.Status</span></td>
                    <td>
                        @if (check.EvidenceLines.Any())
                        {
                            <ul class="mb-0">
                                @foreach (var line in check.EvidenceLines)
                                {
                                    <li>@line</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <span class="text-muted small">No evidence captured.</span>
                        }
                    </td>
                    <td>@check.Confidence.ToString("0.00") <div class="small text-muted">@check.ProvenanceType</div></td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.Parity.Gaps.Any())
    {
        <h4 class="h6">Parity Gaps</h4>
        <ul>
            @foreach (var gap in Model.Parity.Gaps)
            {
                <li>@gap</li>
            }
        </ul>
    }

    <h4 class="h6 mt-3">SQL and Table Parity (Before vs After)</h4>
    <div class="row g-3 mb-2">
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Legacy Queries</small><div class="fw-semibold">@Model.Parity.SqlParity.LegacyQueryCount</div></div></div>
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Converted Queries</small><div class="fw-semibold">@Model.Parity.SqlParity.ConvertedQueryCount</div></div></div>
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Matched Queries</small><div class="fw-semibold">@Model.Parity.SqlParity.MatchedCount</div></div></div>
    </div>

    <div class="table-responsive mb-3">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Table</th>
                    <th>Legacy Count</th>
                    <th>Converted Count</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var t in Model.Parity.SqlParity.Tables)
            {
                <tr>
                    <td><code>@t.Table</code></td>
                    <td>@t.LegacyOccurrences</td>
                    <td>@t.ConvertedOccurrences</td>
                    <td><span class="status-pill @t.Status.ToLowerInvariant()">@t.Status</span></td>
                </tr>
            }
            @if (!Model.Parity.SqlParity.Tables.Any())
            {
                <tr><td colspan="4" class="text-muted">No SQL table evidence found for this run.</td></tr>
            }
            </tbody>
        </table>
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Legacy (Before)</th>
                    <th>Converted (After)</th>
                    <th>Confidence</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var pair in Model.Parity.SqlParity.BeforeAfter)
            {
                <tr>
                    <td><span class="status-pill @pair.Status.ToLowerInvariant()">@pair.Status</span></td>
                    <td>
                        <div class="small"><code>@pair.LegacyFile</code></div>
                        <div class="small"><strong>Tables:</strong> @string.Join(", ", pair.LegacyTables)</div>
                        <div class="small text-muted">@pair.LegacyQuery</div>
                    </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(pair.ConvertedFile))
                        {
                            <div class="small"><code>@pair.ConvertedFile</code></div>
                            <div class="small"><strong>Tables:</strong> @string.Join(", ", pair.ConvertedTables)</div>
                            <div class="small text-muted">@pair.ConvertedQuery</div>
                        }
                        else
                        {
                            <span class="text-muted">No converted match</span>
                        }
                    </td>
                    <td>@pair.Confidence.ToString("0.00")</td>
                </tr>
            }
            @if (!Model.Parity.SqlParity.BeforeAfter.Any())
            {
                <tr><td colspan="4" class="text-muted">No query before/after pairs generated.</td></tr>
            }
            </tbody>
        </table>
    </div>
</section>

<section id="stage-architecture-review" class="stage-section panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">3. Architecture Review</h3>
        <span class="stage-pill">clean architecture + DI + coupling</span>
    </div>
    <div class="row g-3">
        <div class="col-lg-12">
            <div class="pipeline-summary-card">
                <div class="summary-label">Applied Architecture Policy</div>
                <div class="summary-value">@Model.ArchitectureReview.ArchitecturePolicy</div>
                <div class="small text-muted">confidence: @Model.ArchitectureReview.Confidence.ToString("0.00")</div>
            </div>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">Clean Architecture Issues</h4>
            <ul>
                @foreach (var issue in Model.ArchitectureReview.CleanArchitectureIssues)
                {
                    <li><strong>@issue.Severity</strong> - @issue.Title <div class="small text-muted">@issue.Evidence</div></li>
                }
            </ul>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">Namespace / Folder Issues</h4>
            <ul>
                @foreach (var issue in Model.ArchitectureReview.NamespaceFolderIssues)
                {
                    <li><strong>@issue.Severity</strong> - @issue.Title <div class="small text-muted">@issue.Evidence</div></li>
                }
            </ul>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">DI Issues</h4>
            <ul>
                @foreach (var issue in Model.ArchitectureReview.DiIssues)
                {
                    <li><strong>@issue.Severity</strong> - @issue.Title <div class="small text-muted">@issue.Evidence</div></li>
                }
            </ul>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">Coupling Issues</h4>
            <ul>
                @foreach (var issue in Model.ArchitectureReview.CouplingIssues)
                {
                    <li><strong>@issue.Severity</strong> - @issue.Title <div class="small text-muted">@issue.Evidence</div></li>
                }
            </ul>
        </div>
    </div>
    <h4 class="h6 mt-2">Recommended Structure</h4>
    <ul>@foreach (var x in Model.ArchitectureReview.RecommendedStructure) { <li>@x</li> }</ul>
</section>

<section id="stage-test-plan" class="stage-section panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">4. Test Plan</h3>
        <span class="stage-pill">existing + suggested + coverage + category purpose</span>
    </div>
    <p><strong>Coverage Summary:</strong> @Model.TestPlan.CoverageSummary</p>
    @if (Model.TestPlan.ScopeApplied.ScopeTerms.Any())
    {
        <div class="small text-muted mb-2">Scope applied to test plan: @string.Join(", ", Model.TestPlan.ScopeApplied.ScopeTerms) (confidence @Model.TestPlan.Confidence.ToString("0.00"))</div>
    }
    <div class="row g-3">
        <div class="col-lg-6">
            <h4 class="h6">Existing Tests Found</h4>
            <ul>@foreach (var x in Model.TestPlan.ExistingTestsFound) { <li>@x</li> }</ul>
        </div>
        <div class="col-lg-6">
            <h4 class="h6">New Tests Suggested</h4>
            <ul>@foreach (var x in Model.TestPlan.NewTestsSuggested) { <li>@x</li> }</ul>
        </div>
    </div>
    <h4 class="h6 mt-2">Test Categories and Purpose</h4>
    <table class="table table-sm">
        <thead><tr><th>Category</th><th>Purpose</th></tr></thead>
        <tbody>
        @foreach (var c in Model.TestPlan.TestCategories)
        {
            <tr>
                <td>@c.Category</td>
                <td>
                    <div>@c.Purpose</div>
                    @if (c.Scenarios.Any())
                    {
                        <div class="small text-muted">Scenarios:</div>
                        <ul class="mb-0">
                            @foreach (var s in c.Scenarios.Take(3))
                            {
                                <li>@s.Name <span class="badge text-bg-light ms-1">@s.ProvenanceType</span> <span class="text-muted">conf: @s.Confidence.ToString("0.00")</span></li>
                            }
                        </ul>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<section id="stage-execution" class="stage-section panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">5. Execution</h3>
        <span class="stage-pill">unit / integration / e2e / api / edge / playwright / devtools</span>
    </div>

    <div class="execution-grid mb-3">
        @foreach (var c in Model.Execution.TestCategories)
        {
            <article class="execution-kpi-card">
                <div class="d-flex align-items-center justify-content-between mb-1">
                    <h4 class="h6 mb-0">@c.Category</h4>
                    <span class="status-pill @(c.PreflightStatus.ToLowerInvariant())">@c.PreflightStatus</span>
                </div>
                <div class="small text-muted mb-2">@c.Purpose</div>
                <div class="execution-metric-row">
                    <span>Total: <strong>@c.TotalCount</strong></span>
                    <span class="text-success">Passed: <strong>@c.Passed</strong></span>
                    <span class="text-danger">Failed: <strong>@c.Failed</strong></span>
                    <span class="text-warning">Warnings: <strong>@c.Warnings</strong></span>
                </div>
                <div class="execution-metric-row">
                    <span>Generated: <strong>@c.NewTestsAdded</strong></span>
                    <span>Skill: <code>@c.SourceSkill</code></span>
                </div>
                @if (!string.IsNullOrWhiteSpace(c.PreflightReason) && !string.Equals(c.PreflightReason, "ok", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="small text-danger mt-1">Preflight reason: @c.PreflightReason</div>
                }
            </article>
        }
    </div>

    <div class="accordion execution-accordion" id="executionCategoriesAccordion">
    @for (var i = 0; i < Model.Execution.TestCategories.Count; i++)
    {
        var c = Model.Execution.TestCategories[i];
        var generatedScenarios = c.ScenarioDetails.Where(s => s.Generated).ToList();
        var executionFindings = Model.Findings.Findings
            .Where(f => string.Equals(f.Stage, "execution", StringComparison.OrdinalIgnoreCase)
                        && string.Equals(f.SkillName, c.SourceSkill, StringComparison.OrdinalIgnoreCase))
            .ToList();
        var executionRecommendations = Model.Findings.Recommendations
            .Where(r => string.Equals(r.Stage, "execution", StringComparison.OrdinalIgnoreCase)
                        && string.Equals(r.SkillName, c.SourceSkill, StringComparison.OrdinalIgnoreCase))
            .ToList();
        var collapseId = $"execution-category-{i}";
        var headingId = $"execution-heading-{i}";
        var expanded = i == 0;

        <div class="accordion-item execution-category-card mb-2">
            <h2 class="accordion-header" id="@headingId">
                <button class="accordion-button @(expanded ? string.Empty : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="@(expanded ? "true" : "false")" aria-controls="@collapseId">
                    <span class="me-2 fw-semibold">@c.Category</span>
                    <span class="badge text-bg-light border me-2">@c.ScenarioDetails.Count scenario(s)</span>
                    <span class="status-pill @c.PreflightStatus.ToLowerInvariant()">@c.PreflightStatus</span>
                </button>
            </h2>
            <div id="@collapseId" class="accordion-collapse collapse @(expanded ? "show" : string.Empty)" aria-labelledby="@headingId" data-bs-parent="#executionCategoriesAccordion">
                <div class="accordion-body pt-2">
                    <div class="execution-category-header">
                        <h4 class="h6 mb-0">@c.Category Details</h4>
                        <span class="badge text-bg-primary">@c.Passed passed / @c.Failed failed</span>
                    </div>
                    <div class="execution-scope-note mb-2">
                        @if (string.Equals(c.Category, "Integration", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-info-subtle text-info-emphasis border">Integration validates cross-layer service/repository and persistence orchestration.</span>
                        }
                        else if (string.Equals(c.Category, "E2E", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-warning-subtle text-warning-emphasis border">E2E validates browser journey behavior and UX parity from entrypoint to outcome.</span>
                        }
                    </div>

            <div class="table-responsive mb-3">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Scenario</th>
                            <th>Status</th>
                            <th>Coverage</th>
                            <th>Generated</th>
                            <th>Provenance</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (c.ScenarioDetails.Any())
                    {
                        @foreach (var s in c.ScenarioDetails)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@s.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(s.Notes))
                                    {
                                        <div class="small text-muted">@s.Notes</div>
                                    }
                                </td>
                                <td><span class="status-pill @s.Status.ToLowerInvariant()">@s.Status</span></td>
                                <td>
                                    @if (s.Coverage.Any())
                                    {
                                        @foreach (var cov in s.Coverage)
                                        {
                                            <span class="badge text-bg-light border me-1 mb-1">@cov</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">n/a</span>
                                    }
                                </td>
                                <td>
                                    @if (s.Generated)
                                    {
                                        <span class="badge text-bg-warning">Generated</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Existing</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge text-bg-light border">@s.ProvenanceType</span>
                                    <div class="small text-muted">conf: @s.Confidence.ToString("0.00")</div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        @foreach (var s in c.ScenariosCovered)
                        {
                            <tr>
                                <td>@s</td>
                                <td><span class="status-pill unknown">unknown</span></td>
                                <td><span class="text-muted small">n/a</span></td>
                                <td><span class="badge text-bg-secondary">Unknown</span></td>
                                <td><span class="badge text-bg-light border">inferred</span></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>

            <div class="row g-3">
                <div class="col-lg-4">
                    <h5 class="h6">Generated Test Cases</h5>
                    @if (generatedScenarios.Any())
                    {
                        <ul class="mb-0">
                            @foreach (var s in generatedScenarios)
                            {
                                <li>
                                    @s.Name
                                    @if (s.GeneratedFrom.Any())
                                    {
                                        <div class="small text-muted">from: @string.Join(", ", s.GeneratedFrom)</div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="small text-muted">No generated tests recorded for this category in this run.</div>
                    }
                </div>

                <div class="col-lg-4">
                    <h5 class="h6">Failure Reasons</h5>
                    @if (executionFindings.Any())
                    {
                        <ul class="mb-0">
                            @foreach (var f in executionFindings)
                            {
                                <li>
                                    <strong>@f.FindingType</strong>: @f.Message
                                    <div class="small text-muted">Cause: @f.LikelyCause</div>
                                    <div class="small text-muted">Evidence: @f.Evidence</div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="small text-muted">No execution findings recorded.</div>
                    }
                </div>

                <div class="col-lg-4">
                    <h5 class="h6">Resolution Guidance</h5>
                    @if (executionRecommendations.Any())
                    {
                        <ul class="mb-0">
                            @foreach (var r in executionRecommendations)
                            {
                                <li>
                                    <strong>@r.Priority</strong>: @r.Message
                                    <div class="small text-muted">@r.Evidence</div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="small text-muted">No recommendations recorded.</div>
                    }
                </div>
            </div>

                    <div class="row g-3 mt-1">
                <div class="col-lg-6">
                    <h5 class="h6">Execution Logs</h5>
                    @if (c.Logs.Any())
                    {
                        <ul class="mb-0">@foreach (var log in c.Logs) { <li><code>@log</code></li> }</ul>
                    }
                    else
                    {
                        <div class="small text-muted">No logs recorded.</div>
                    }
                </div>
                <div class="col-lg-6">
                    <h5 class="h6">Artifacts</h5>
                    @if (c.Artifacts.Any())
                    {
                        <ul class="mb-0">@foreach (var artifact in c.Artifacts) { <li><code>@artifact</code></li> }</ul>
                    }
                    else
                    {
                        <div class="small text-muted">No artifacts recorded.</div>
                    }
                </div>
            </div>
                </div>
            </div>
        </div>
    }
    </div>

    <h4 class="h6 mt-3">Playwright / Browser Verification Evidence</h4>
    <div class="mb-2">
        <span class="status-pill @Model.Execution.Playwright.Status.ToLowerInvariant()">@Model.Execution.Playwright.Status</span>
        <span class="ms-2">@Model.Execution.Playwright.Summary</span>
    </div>

    <div class="mb-3">
        <span class="badge @((string.Equals(Model.Execution.Playwright.TestApiStatus, "present", StringComparison.OrdinalIgnoreCase) || string.Equals(Model.Execution.Playwright.TestApiStatus, "fallback-attached", StringComparison.OrdinalIgnoreCase)) ? "text-bg-success" : "text-bg-danger")">
            Test API: @(string.Equals(Model.Execution.Playwright.TestApiStatus, "present", StringComparison.OrdinalIgnoreCase)
                ? "Present"
                : string.Equals(Model.Execution.Playwright.TestApiStatus, "fallback-attached", StringComparison.OrdinalIgnoreCase)
                    ? "Fallback Attached"
                    : "Missing")
        </span>
        @if (!string.IsNullOrWhiteSpace(Model.Execution.Playwright.TestApiEndpoint))
        {
            <span class="ms-2"><code>@Model.Execution.Playwright.TestApiEndpoint</code></span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Execution.Playwright.TestApiSource))
        {
            <span class="badge text-bg-light border ms-2">source: @Model.Execution.Playwright.TestApiSource</span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Execution.Playwright.TestApiReason))
        {
            <div class="small text-muted mt-1">Reason: @Model.Execution.Playwright.TestApiReason</div>
        }
        @if (Model.Execution.Playwright.TestApiAutoProvisioned)
        {
            <div class="small text-muted mt-1">Fallback diagnostics endpoint was auto-attached for this run because module-hosted test API was unavailable.</div>
        }
        <div class="small text-muted mt-1">This indicates diagnostics endpoint availability, not whether previous iteration tests exist.</div>
    </div>

    @if (missingTestApi)
    {
        <div class="alert alert-warning mb-3">
            <div class="fw-semibold mb-1">Diagnostics endpoint missing for this run input.</div>
            <div class="small mb-2">The app does not auto-create a diagnostics API in your target module host. Use the dashboard-provided endpoint or expose /api/test in the converted app.</div>
            <div class="small">
                Suggested endpoint for next run input:
                <code>@fallbackTestApiEndpoint</code>
            </div>
            <div class="small mt-1">
                <a href="@($"{fallbackTestApiEndpoint}/health")" target="_blank" rel="noopener">Check fallback health endpoint</a>
            </div>
        </div>
    }

    <div class="row g-3">
        <div class="col-lg-6">
            <h5 class="h6">Scenarios</h5>
            <ul>
                @foreach (var s in Model.Execution.Playwright.Scenarios)
                {
                    <li><strong>@s.Status</strong> - @s.Name <div class="small text-muted">@s.Notes</div></li>
                }
            </ul>
        </div>
        <div class="col-lg-6">
            <h5 class="h6">Console Errors</h5>
            <ul>@foreach (var x in Model.Execution.Playwright.ConsoleErrors) { <li>@x</li> }</ul>
            <h5 class="h6">Console Warnings</h5>
            <ul>@foreach (var x in Model.Execution.Playwright.ConsoleWarnings) { <li>@x</li> }</ul>
        </div>
        <div class="col-lg-6">
            <h5 class="h6">Network Failures</h5>
            <ul>@foreach (var x in Model.Execution.Playwright.NetworkFailures) { <li>@x</li> }</ul>
            <h5 class="h6">DOM / State Checks</h5>
            <ul>@foreach (var x in Model.Execution.Playwright.DomStateChecks) { <li>@x</li> }</ul>
        </div>
        <div class="col-lg-6">
            <h5 class="h6">Runtime Issues</h5>
            <ul>@foreach (var x in Model.Execution.Playwright.RuntimeIssues) { <li>@x</li> }</ul>
            <h5 class="h6">Performance Observations</h5>
            <ul>@foreach (var x in Model.Execution.Playwright.PerformanceObservations) { <li>@x</li> }</ul>
        </div>
    </div>

    <h5 class="h6 mt-2">Screenshots</h5>
    @if (screenshotArtifacts.Any())
    {
        <div class="screenshot-grid">
            @foreach (var screenshotPath in screenshotArtifacts)
            {
                var screenshotUrl = Url.Action("ArtifactFile", "Dashboard", new { path = screenshotPath }) ?? string.Empty;
                <a class="screenshot-card" href="@screenshotUrl" target="_blank" rel="noopener">
                    <img src="@screenshotUrl" alt="Playwright evidence screenshot" loading="lazy" />
                    <span class="small text-muted">@System.IO.Path.GetFileName(screenshotPath)</span>
                </a>
            }
        </div>
    }
    else
    {
        <div class="small text-muted">No screenshots captured for this run.</div>
    }
</section>

<section id="stage-findings" class="stage-section panel-card p-3 mb-3">
    <div class="stage-heading">
        <h3 class="h5 mb-0">6. Findings</h3>
        <span class="stage-pill">failed scenarios / likely causes / recommendations</span>
    </div>

    <div class="findings-summary-strip mb-3">
        <span class="badge text-bg-light border">Total: @Model.Findings.Findings.Count</span>
        <span class="badge text-bg-light border">Open: @Model.Findings.Findings.Count(static f => string.Equals(f.Status, "open", StringComparison.OrdinalIgnoreCase))</span>
        <span class="badge text-bg-light border">High severity: @Model.Findings.Findings.Count(static f => string.Equals(f.Severity, "high", StringComparison.OrdinalIgnoreCase))</span>
        <span class="badge text-bg-light border">Recommendations: @Model.Findings.Recommendations.Count</span>
    </div>

    <details class="findings-details" open>
        <summary class="mb-2">Detailed Findings Matrix</summary>
        <div class="table-responsive mb-3">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Stage</th>
                    <th>Type</th>
                    <th>Scenario</th>
                    <th>Likely Cause</th>
                    <th>Evidence</th>
                    <th>Confidence</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var f in Model.Findings.Findings)
            {
                <tr>
                    <td>@f.Stage</td>
                    <td>@f.FindingType</td>
                    <td>@f.Scenario</td>
                    <td>@f.LikelyCause</td>
                    <td>@f.Evidence</td>
                    <td>@f.Confidence.ToString("0.00")<div class="small text-muted">@f.ProvenanceType</div></td>
                    <td>
                        <span class="status-pill @f.Status.ToLowerInvariant()">@f.Status</span>
                        @if (!string.IsNullOrWhiteSpace(f.ResolvedInRunId))
                        {
                            <div class="small text-muted">resolved in @f.ResolvedInRunId</div>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    </details>

    <div class="row g-3 mb-3">
        <div class="col-lg-6">
            <h4 class="h6">Key Learnings</h4>
            <div class="small text-muted mb-1">Persistent modernization pitfalls captured from repeated runs.</div>
            <ul class="mb-0">
                @foreach (var pitfall in Model.KeyLearnings.KnownPitfalls)
                {
                    <li>@pitfall</li>
                }
            </ul>
            @if (!Model.KeyLearnings.KnownPitfalls.Any())
            {
                <div class="small text-muted">No key learnings recorded yet.</div>
            }
        </div>
        <div class="col-lg-6">
            <h4 class="h6">Recurring Signatures</h4>
            <ul class="mb-0">
                @foreach (var signature in Model.KeyLearnings.RecurringSignatures)
                {
                    <li>@signature</li>
                }
            </ul>
            @if (!Model.KeyLearnings.RecurringSignatures.Any())
            {
                <div class="small text-muted">No recurring signatures for this module run.</div>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <h4 class="h6">New Issues</h4>
            <ul class="mb-0">@foreach (var x in Model.KeyLearnings.NewIssues) { <li>@x</li> }</ul>
            @if (!Model.KeyLearnings.NewIssues.Any())
            {
                <div class="small text-muted">No new issues introduced.</div>
            }
        </div>
        <div class="col-lg-4">
            <h4 class="h6">Recurring Issues</h4>
            <ul class="mb-0">@foreach (var x in Model.KeyLearnings.RecurringIssues) { <li>@x</li> }</ul>
            @if (!Model.KeyLearnings.RecurringIssues.Any())
            {
                <div class="small text-muted">No recurring issues for this run.</div>
            }
        </div>
        <div class="col-lg-4">
            <h4 class="h6">Resolved Issues</h4>
            <ul class="mb-0">@foreach (var x in Model.KeyLearnings.ResolvedIssues) { <li>@x</li> }</ul>
            @if (!Model.KeyLearnings.ResolvedIssues.Any())
            {
                <div class="small text-muted">No resolved issues detected from previous run.</div>
            }
        </div>
    </div>

    <h4 class="h6">Recommendations</h4>
    <ul>
    @foreach (var r in Model.Findings.Recommendations)
    {
        <li><strong>@r.Priority</strong> - @r.Message <span class="text-muted">(@r.Stage / @r.SkillName / @r.ProvenanceType)</span></li>
    }
    </ul>
</section>

<section id="stage-iteration-comparison" class="stage-section panel-card p-3 mb-4">
    <div class="stage-heading">
        <h3 class="h5 mb-0">7. Iteration Comparison and Improvements</h3>
        <span class="stage-pill">previous vs current progression and quality uplift</span>
    </div>

    <div class="row g-3">
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Previous Run</small><div class="fw-semibold">@Model.IterationComparison.PreviousRunId</div></div></div>
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Tests Added</small><div class="fw-semibold">@Model.IterationComparison.TestsAdded</div></div></div>
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Tests Fixed</small><div class="fw-semibold">@Model.IterationComparison.TestsFixed</div></div></div>
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Failures Reduced</small><div class="fw-semibold">@Model.IterationComparison.FailuresReduced</div></div></div>
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">New Findings Introduced</small><div class="fw-semibold">@Model.IterationComparison.NewFindingsIntroduced</div></div></div>
        <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Resolved Findings</small><div class="fw-semibold">@Model.IterationComparison.ResolvedFindings</div></div></div>
    </div>
    <div class="mt-2">
        <strong>Trend:</strong> <span class="status-pill @Model.IterationComparison.ProgressionTrend.ToLowerInvariant()">@Model.IterationComparison.ProgressionTrend</span>
    </div>
</section>
