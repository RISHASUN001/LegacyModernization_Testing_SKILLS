{
  "name": "lessons-learned",
  "stage": "findings",
  "category": "knowledge",
  "purpose": "Capture lessons, resolved issue context, and repeatable fixes from each modernization run.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "runId"
  ],
  "optionalInputs": [
    "failureDiagnosisReport"
  ],
  "outputFiles": [
    "result.json",
    "lessons-learned.json",
    "lessons.json",
    "../_knowledge-base/lessons-kb.json"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/lessons-learned/"
  ],
  "dependencies": [
    "failure-diagnosis",
    "parity-verification"
  ],
  "summaryOutputType": "lessons-summary",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>"
    ]
  }
}
