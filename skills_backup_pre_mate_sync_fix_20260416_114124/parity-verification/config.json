{
  "name": "parity-verification",
  "stage": "functional-parity",
  "category": "parity",
  "purpose": "Verify converted module behavior parity against legacy baselines and identify gaps.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "legacySourceRoot",
    "convertedSourceRoot"
  ],
  "optionalInputs": [
    "moduleDocumentationArtifact"
  ],
  "outputFiles": [
    "result.json",
    "parity-diff.json",
    "functional-parity-map.json",
    "workflow-parity-summary.json",
    "sql-parity-map.json",
    "table-parity-map.json",
    "preservation-score.json"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/parity-verification/"
  ],
  "dependencies": [
    "csharp-logic-understanding",
    "java-logic-understanding",
    "java-counterpart-discovery",
    "excalidraw-diagram"
  ],
  "summaryOutputType": "parity-summary",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>"
    ]
  }
}
