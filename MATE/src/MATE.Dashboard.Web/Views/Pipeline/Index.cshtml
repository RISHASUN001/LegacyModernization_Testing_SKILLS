@model MATE.Dashboard.Web.Models.Pipeline.PipelineHomeDto
@{
    ViewData["Title"] = "MATE Pipeline";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">MATE Pipeline Dashboard</h2>
        <div class="text-muted small">10-stage modularity verification and modernization fidelity checks</div>
    </div>
    <a class="btn btn-primary" asp-controller="Pipeline" asp-action="Input"><i class="bi bi-plus-circle me-2"></i>Create Run Input</a>
</div>

@if (Model.Modules.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-lg-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Total Modules</div>
                    <div class="h4 mb-0">@Model.Modules.Count</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Total Runs</div>
                    <div class="h4 mb-0">@Model.TotalRuns</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <strong>Modules & Latest Runs</strong>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0 align-middle">
                <thead>
                <tr>
                    <th>Module</th>
                    <th>Run Count</th>
                    <th>Latest Run ID</th>
                    <th>Status</th>
                    <th>Ended</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var module in Model.Modules.OrderByDescending(m => m.RunCount))
                {
                    <tr>
                        <td><strong>@module.ModuleName</strong></td>
                        <td><span class="badge text-bg-secondary">@module.RunCount</span></td>
                        <td><code>@module.LatestRunId</code></td>
                        <td>
                            <span class="badge @(module.LatestStatus == "passed" ? "text-bg-success" : module.LatestStatus == "failed" ? "text-bg-danger" : module.LatestStatus == "in-progress" ? "text-bg-info" : "text-bg-secondary")">
                                @module.LatestStatus
                            </span>
                        </td>
                        <td class="small text-muted">@module.LatestEndedAt</td>
                        <td><a class="btn btn-sm btn-outline-primary" asp-controller="Pipeline" asp-action="Run" asp-route-moduleName="@module.ModuleName" asp-route-runId="@module.LatestRunId">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No runs discovered yet. <a asp-controller="Pipeline" asp-action="Input">Create a run input</a> to get started.</div>
}
