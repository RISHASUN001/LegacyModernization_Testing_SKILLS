<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Legacy Application - Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-container {
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            padding: 40px;
            width: 100%;
            max-width: 400px;
        }
        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .login-header h1 {
            font-size: 24px;
            color: #333;
            margin-bottom: 5px;
        }
        .login-header p {
            color: #666;
            font-size: 14px;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-control {
            border: 1px solid #ddd;
            padding: 12px;
            border-radius: 5px;
        }
        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
        .btn-login {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 12px;
            border: none;
            border-radius: 5px;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        .alert {
            margin-bottom: 20px;
        }
        .test-credentials {
            background: #f0f0f0;
            padding: 15px;
            border-radius: 5px;
            margin-top: 20px;
            font-size: 13px;
        }
        .test-credentials p {
            margin: 0;
            color: #666;
        }
        .test-credentials strong {
            color: #333;
        }
        .badge {
            background: #667eea;
            color: white;
            padding: 5px 10px;
            border-radius: 3px;
            font-size: 11px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <h1>Legacy App (Converted)</h1>
            <p>ASP.NET Core version of Java/JSP</p>
            <span class="badge">Testing URL: http://localhost:5001</span>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" role="alert">
                @TempData["Error"]
            </div>
        }

        <form method="post" action="/login" id="loginForm">
            <div class="form-group">
                <label for="email">Email / Username</label>
                <input type="text" class="form-control" id="email" name="email" placeholder="admin" required autofocus>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" class="form-control" id="password" name="password" placeholder="password123" required>
            </div>

            <div class="form-group">
                <label for="module">Module</label>
                <select class="form-control" id="module" name="module">
                    <option value="Dashboard">Dashboard</option>
                    <option value="Analytics">Analytics</option>
                    <option value="Reports">Reports</option>
                </select>
            </div>

            <button type="submit" class="btn-login">Login</button>
        </form>

        <div class="test-credentials">
            <p><strong>Test Credentials:</strong></p>
            <p>Email: <code>admin</code></p>
            <p>Password: <code>password123</code></p>
            <p style="margin-top: 10px; color: #999; font-size: 12px;">
                This app serves as the "legacy" version for testing.
                Use this URL in Dashboard Input Builder for Playwright tests.
            </p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
