{
  "name": "clean-architecture-assessment",
  "stage": "architecture-review",
  "category": "architecture",
  "purpose": "Assess converted C# module against clean architecture boundaries and target structure guidance.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "convertedSourceRoot"
  ],
  "optionalInputs": [
    "moduleHints.relatedFolders"
  ],
  "outputFiles": [
    "result.json",
    "architecture-review.json"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/clean-architecture-assessment/"
  ],
  "dependencies": [
    "module-documentation"
  ],
  "summaryOutputType": "architecture-review",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>"
    ]
  }
}
