{
  "name": "failure-diagnosis",
  "stage": "findings",
  "category": "diagnostics",
  "purpose": "Correlate failed scenarios across execution stages and propose likely causes with evidence-backed recommendations.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "runId"
  ],
  "optionalInputs": [
    "failedSkillArtifacts"
  ],
  "outputFiles": [
    "result.json",
    "diagnosis-report.json"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/failure-diagnosis/"
  ],
  "dependencies": [
    "unit-test-execution",
    "integration-test-execution",
    "e2e-test-execution",
    "api-test-execution",
    "edge-case-testing",
    "playwright-browser-verification"
  ],
  "summaryOutputType": "failure-diagnosis",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>"
    ]
  }
}
