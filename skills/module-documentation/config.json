{
  "name": "module-documentation",
  "stage": "logic-understanding",
  "category": "documentation",
  "purpose": "Create module documentation artifact used by dashboard Logic Understanding stage.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "runId"
  ],
  "optionalInputs": [
    "brsPath"
  ],
  "outputFiles": [
    "result.json",
    "module-analysis.json"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/module-documentation/"
  ],
  "dependencies": [
    "legacy-logic-extraction"
  ],
  "summaryOutputType": "module-document",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>"
    ]
  }
}
