{
  "name": "e2e-test-execution",
  "stage": "execution",
  "category": "testing",
  "purpose": "Execute end-to-end scenarios validating complete workflow continuity from UI to persistence.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "baseUrl"
  ],
  "optionalInputs": [
    "environmentProfile"
  ],
  "outputFiles": [
    "result.json",
    "preflight.json",
    "execution-log.txt",
    "e2e-scenarios.json",
    "screenshots/*"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/e2e-test-execution/"
  ],
  "dependencies": [
    "test-plan-generation",
    "api-test-execution"
  ],
  "summaryOutputType": "test-category-result",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "python3 -m pytest -m e2e",
      "testCommands.e2e from run input"
    ]
  }
}
