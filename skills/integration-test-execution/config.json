{
  "name": "integration-test-execution",
  "stage": "execution",
  "category": "testing",
  "purpose": "Execute integration tests for data mapping and cross-layer orchestration validation.",
  "scriptEntry": "run.py",
  "requiredInputs": [
    "moduleName",
    "convertedSourceRoot"
  ],
  "optionalInputs": [
    "connectionStringOverride"
  ],
  "outputFiles": [
    "result.json",
    "preflight.json",
    "execution-log.txt"
  ],
  "artifactFolders": [
    "artifacts/{module}/{runId}/integration-test-execution/"
  ],
  "dependencies": [
    "test-plan-generation",
    "unit-test-execution"
  ],
  "summaryOutputType": "test-category-result",
  "resultContractVersion": "2.0",
  "externalDependencies": [],
  "execution": {
    "primaryCommand": "python run.py --input <module-run-input.json> --artifacts-root <artifacts-root>",
    "timeoutNotes": "Real-first graceful execution. Writes result.json even on degraded/failure paths.",
    "realCommandHints": [
      "dotnet test <IntegrationTests.csproj>",
      "testCommands.integration from run input"
    ]
  }
}
